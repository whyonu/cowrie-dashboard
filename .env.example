# VirusTotal API
VT_KEY=your_virustotal_api_key

# Cowrie paths
DOWNLOADS_DIR=/opt/honeypot/cowrie-data/downloads/
TTY_DIR=/opt/honeypot/cowrie-data/tty/
LOG_GLOB=/opt/honeypot/cowrie-data/cowrie.json*

# SQLite database
DB_PATH=/opt/honeypot/bot/honeypot.db

# Cowrie container settings (for TTY replay)
COWRIE_CONTAINER=cowrie_honeypot
COWRIE_TTY_PATH=/cowrie/cowrie-git/var/lib/cowrie/tty
COWRIE_PYTHON=/cowrie/cowrie-env/bin/python
COWRIE_PLAYLOG=/cowrie/cowrie-git/src/cowrie/scripts/playlog.py
